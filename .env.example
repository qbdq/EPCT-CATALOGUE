# --- App ---
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PORT=3000

# --- Payload CMS ---
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=dev-secret-change-me-32chars-min-aaaaaaaaaaaaaaaaaa

# --- PostgreSQL ---
DATABASE_URI=postgresql://epct_user:epct_dev_pw@localhost:55432/epct_db

# --- MinIO (S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=epct_admin
S3_SECRET_KEY=epct_dev_pw
S3_BUCKET=epct-media
S3_FORCE_PATH_STYLE=true
NEXT_PUBLIC_MEDIA_URL=http://localhost:9000/epct-media

# --- Revalidation ---
REVALIDATE_SECRET=dev-revalidate-secret

# --- Email (use MailHog locally) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="EPCT Dev <dev@epct.local>"
CONTACT_EMAIL=dev@epct.local
